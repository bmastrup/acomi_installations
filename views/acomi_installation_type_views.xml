<odoo>
    <data>
        <record id="view_acomi_installation_type_list" model="ir.ui.view">
            <field name="name">acomi.installation.type.list</field>
            <field name="model">acomi.installation.type</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_acomi_installation_type_form" model="ir.ui.view">
            <field name="name">acomi.installation.type.form</field>
            <field name="model">acomi.installation.type</field>
            <field name="arch" type="xml">
                <form string="Anlægstype">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <field name="active"/>
                        </group>
                        <notebook>
                            <page string="Beskrivelse">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_acomi_installation_type" model="ir.actions.act_window">
            <field name="name">Anlægstyper</field>
            <field name="res_model">acomi.installation.type</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
